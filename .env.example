# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control.

# Polymarket CLOB credentials (from Polymarket API key setup)
POLYMARKET_PRIVATE_KEY=your_polygon_wallet_private_key_here
POLYMARKET_API_KEY=your_polymarket_api_key_here
POLYMARKET_API_SECRET=your_polymarket_api_secret_here
POLYMARKET_API_PASSPHRASE=your_polymarket_api_passphrase_here

# Optional overrides
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
CYCLE_INTERVAL_SECONDS=300
