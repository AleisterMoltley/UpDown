# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control.

# ============================================================================
# Telegram Bot Configuration (REQUIRED)
# ============================================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram chat ID (ONLY this ID can control the bot)
# Send /start to @userinfobot to get your ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ============================================================================
# Polymarket 100% Onchain Mode (2026)
# ============================================================================
# Nur noch der Private Key wird benötigt!
# L2-API-Credentials werden automatisch abgeleitet (EOA signature_type=0)
POLYMARKET_PRIVATE_KEY=your_polygon_wallet_private_key_here

# Optional overrides
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
CYCLE_INTERVAL_SECONDS=300

# Moving average strategy configuration
SHORT_WINDOW=5
LONG_WINDOW=20

# ============================================================================
# Polygon RPC Configuration
# ============================================================================
# Polygon Mainnet RPC URL für onchain-Transaktionen
POLYGON_RPC_URL=https://polygon-rpc.com

# ============================================================================
# Solana Auto-Funding Configuration (Can be set via Telegram /set_solana_key)
# ============================================================================
# When configured, the bot will automatically bridge USDC from Solana to
# Polygon when your trading balance falls below MIN_POLY_BALANCE_USDC.
#
# ⚠️  SECURITY WARNING: Private keys grant full control over your funds.
#     - NEVER share your private keys with anyone
#     - NEVER commit .env or private keys to source control
#     - Consider using a dedicated trading wallet with limited funds
# ============================================================================

# Your Solana wallet private key (base58 encoded)
# To export from Phantom: Settings > Security & Privacy > Export Private Key
SOLANA_PRIVATE_KEY=your_base58_solana_private_key_here

# Solana RPC endpoint (default: mainnet)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Minimum Polygon USDC balance before triggering auto-bridge (default: 20.0)
MIN_POLY_BALANCE_USDC=20.0

# Amount of USDC to bridge when triggered (default: 50.0)
BRIDGE_FUND_AMOUNT=50.0

# ============================================================================
# Auto MATIC Top-Up Configuration
# ============================================================================
# Nach erfolgreichen Trades wird automatisch USDC → MATIC getauscht
# um Gas-Kosten zu decken
AUTO_MATIC_TOPUP_ENABLED=true
AUTO_MATIC_TOPUP_MIN_PROFIT=0.5
AUTO_MATIC_TOPUP_AMOUNT=0.20
